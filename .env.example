# LLM provider — uncomment the one you want to use
DEEPSEEK_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# GEMINI_API_KEY=...

# Active LLM provider: "anthropic", "openai", "gemini" or "deepseek"
LLM_PROVIDER=deepseek

# LLM model to use
LLM_MODEL=deepseek-reasoner

# Embeddings — Hugging Face Inference API
# Same key as your HF Spaces deployment
HUGGINGFACE_API_KEY=hf_...

# Embedding provider (currently only "huggingface" is supported)
EMBEDDING_PROVIDER=huggingface

# Embedding model — best open-source multilingual retrieval model for Spanish
EMBEDDING_MODEL=intfloat/multilingual-e5-large-instruct

# Maximum number of PDFs processed in parallel
MAX_PARALLEL_PDFS=4

# Maximum session duration in minutes before temporary files are cleaned up
SESSION_TIMEOUT_MINUTES=60

# Chunk size in characters for text splitting
CHUNK_SIZE=1000
CHUNK_OVERLAP=200