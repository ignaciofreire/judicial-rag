# LLM provider — uncomment the one you want to use
DEEPSEEK_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# GEMINI_API_KEY=...

# Active provider: "anthropic", "openai", "gemini" or "deepseek"
LLM_PROVIDER=deepseek

# Model to use
LLM_MODEL=deepseek-chat

# Maximum number of PDFs processed in parallel
MAX_PARALLEL_PDFS=4

# Maximum session duration in minutes before temporary files are cleaned up
SESSION_TIMEOUT_MINUTES=60

# Chunk size in characters for text splitting
CHUNK_SIZE=1000
CHUNK_OVERLAP=200